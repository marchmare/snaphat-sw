[Unit]
Description=SnapHAT app
After=dev-mmcblk0p2.device systemd-remount-fs.service
Wants=dev-mmcblk0p2.device systemd-remount-fs.service

[Service]
Type=simple
User=root 
WorkingDirectory=/home/pi/snaphat 
ExecStart=/home/pi/snaphat-sw/.venv/bin/python -u /home/pi/snaphat-sw/main.py 
Restart=always
RestartSec=2
StandardOutput=journal
StandardError=journal
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
